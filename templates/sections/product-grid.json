{
  "type": "productGrid",
  "settings": {
    "heading": {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "defaultValue": "Featured Products"
    },
    "collectionId": {
      "type": "text",
      "id": "collectionId",
      "label": "Collection ID",
      "defaultValue": "featured"
    },
    "numberOfProducts": {
      "type": "number",
      "id": "numberOfProducts",
      "label": "Number of Products",
      "defaultValue": 8
    },
    "columns": {
      "type": "number",
      "id": "columns",
      "label": "Columns (Desktop)",
      "defaultValue": 4
    },
    "mobileColumns": {
      "type": "number",
      "id": "mobileColumns",
      "label": "Columns (Mobile)",
      "defaultValue": 2
    },
    "showQuickAdd": {
      "type": "checkbox",
      "id": "showQuickAdd",
      "label": "Show Quick Add Button",
      "defaultValue": true
    },
    "cardStyle": {
      "type": "select",
      "id": "cardStyle",
      "label": "Product Card Style",
      "options": ["standard", "minimal", "overlay"],
      "defaultValue": "standard"
    }
  }
}
