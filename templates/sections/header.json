{
  "type": "header",
  "settings": {
    "storeName": {
      "type": "text",
      "id": "storeName",
      "label": "Store Name",
      "defaultValue": "My Store"
    },
    "logoImage": {
      "type": "image",
      "id": "logoImage",
      "label": "Logo Image",
      "defaultValue": ""
    },
    "logoWidth": {
      "type": "number",
      "id": "logoWidth",
      "label": "Logo Width (px)",
      "defaultValue": 120
    },
    "logoPosition": {
      "type": "select",
      "id": "logoPosition",
      "label": "Logo Position",
      "defaultValue": "left",
      "options": ["left", "center", "right"]
    },
    "transparentHeader": {
      "type": "checkbox",
      "id": "transparentHeader",
      "label": "Transparent Header",
      "defaultValue": false
    },
    "stickyHeader": {
      "type": "checkbox",
      "id": "stickyHeader",
      "label": "Sticky Header on Scroll",
      "defaultValue": true
    }
  },
  "blocks": [
    {
      "type": "menu_item",
      "settings": {
        "label": {
          "type": "text",
          "id": "label",
          "label": "Label",
          "defaultValue": "Home"
        },
        "link": {
          "type": "text",
          "id": "link",
          "label": "Link",
          "defaultValue": "/"
        },
        "openInNewTab": {
          "type": "checkbox",
          "id": "openInNewTab",
          "label": "Open in new tab",
          "defaultValue": false
        }
      }
    }
  ]
}
