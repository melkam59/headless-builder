{
  "type": "imageWithText",
  "settings": {
    "layout": {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": ["image-left", "image-right"],
      "defaultValue": "image-left"
    },
    "image": {
      "type": "image",
      "id": "image",
      "label": "Image",
      "defaultValue": "https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=800&h=800&fit=crop"
    },
    "imageRatio": {
      "type": "select",
      "id": "imageRatio",
      "label": "Image Ratio",
      "options": ["square", "portrait", "landscape"],
      "defaultValue": "square"
    }
  },
  "blocks": [
    {
      "type": "group",
      "settings": {
        "padding": {
          "type": "number",
          "id": "padding",
          "label": "Content Padding (px)",
          "defaultValue": 48
        }
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": {
              "type": "text",
              "id": "text",
              "label": "Heading",
              "defaultValue": "Crafted with Care"
            },
            "size": {
              "type": "select",
              "id": "size",
              "label": "Heading Size",
              "options": ["small", "medium", "large"],
              "defaultValue": "large"
            }
          }
        },
        {
          "type": "text",
          "settings": {
            "text": {
              "type": "text",
              "id": "text",
              "label": "Text Content",
              "defaultValue": "Every product is carefully selected and crafted to meet our high standards of quality and sustainability."
            }
          }
        },
        {
          "type": "button",
          "settings": {
            "label": {
              "type": "text",
              "id": "label",
              "label": "Button Label",
              "defaultValue": "Our Story"
            },
            "link": {
              "type": "url",
              "id": "link",
              "label": "Button Link",
              "defaultValue": "/pages/about"
            }
          }
        }
      ]
    }
  ]
}
