{
  "type": "hero",
  "settings": {
    "layout": {
      "type": "select",
      "id": "layout",
      "label": "Layout Style",
      "options": ["full-width", "contained", "split"],
      "defaultValue": "full-width"
    },
    "height": {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": ["small", "medium", "large", "full-screen"],
      "defaultValue": "large"
    },
    "mobileHeight": {
      "type": "select",
      "id": "mobileHeight",
      "label": "Mobile Height",
      "options": ["small", "medium", "large"],
      "defaultValue": "medium"
    },
    "backgroundImage": {
      "type": "image",
      "id": "backgroundImage",
      "label": "Background Image",
      "defaultValue": "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1600&h=900&fit=crop"
    },
    "overlayOpacity": {
      "type": "number",
      "id": "overlayOpacity",
      "label": "Overlay Opacity (0-100)",
      "defaultValue": 30
    }
  },
  "blocks": [
    {
      "type": "group",
      "settings": {
        "alignment": {
          "type": "select",
          "id": "alignment",
          "label": "Content Alignment",
          "options": ["left", "center", "right"],
          "defaultValue": "center"
        },
        "verticalAlignment": {
          "type": "select",
          "id": "verticalAlignment",
          "label": "Vertical Alignment",
          "options": ["top", "center", "bottom"],
          "defaultValue": "center"
        },
        "maxWidth": {
          "type": "number",
          "id": "maxWidth",
          "label": "Max Width (px)",
          "defaultValue": 600
        }
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": {
              "type": "text",
              "id": "text",
              "label": "Heading Text",
              "defaultValue": "Discover Your Style"
            },
            "size": {
              "type": "select",
              "id": "size",
              "label": "Heading Size",
              "options": ["small", "medium", "large", "xlarge"],
              "defaultValue": "xlarge"
            },
            "color": {
              "type": "color",
              "id": "color",
              "label": "Text Color",
              "defaultValue": "#ffffff"
            }
          }
        },
        {
          "type": "text",
          "settings": {
            "text": {
              "type": "text",
              "id": "text",
              "label": "Subtext",
              "defaultValue": "Explore our curated collection of premium products"
            },
            "size": {
              "type": "select",
              "id": "size",
              "label": "Text Size",
              "options": ["small", "medium", "large"],
              "defaultValue": "medium"
            },
            "color": {
              "type": "color",
              "id": "color",
              "label": "Text Color",
              "defaultValue": "#ffffff"
            }
          }
        },
        {
          "type": "buttonGroup",
          "settings": {
            "spacing": {
              "type": "number",
              "id": "spacing",
              "label": "Button Spacing (px)",
              "defaultValue": 16
            }
          },
          "blocks": [
            {
              "type": "button",
              "settings": {
                "label": {
                  "type": "text",
                  "id": "label",
                  "label": "Button Label",
                  "defaultValue": "Shop Now"
                },
                "link": {
                  "type": "url",
                  "id": "link",
                  "label": "Button Link",
                  "defaultValue": "/collections/all"
                },
                "style": {
                  "type": "select",
                  "id": "style",
                  "label": "Button Style",
                  "options": ["primary", "secondary", "outline"],
                  "defaultValue": "primary"
                }
              }
            },
            {
              "type": "button",
              "settings": {
                "label": {
                  "type": "text",
                  "id": "label",
                  "label": "Button Label",
                  "defaultValue": "Learn More"
                },
                "link": {
                  "type": "url",
                  "id": "link",
                  "label": "Button Link",
                  "defaultValue": "/pages/about"
                },
                "style": {
                  "type": "select",
                  "id": "style",
                  "label": "Button Style",
                  "options": ["primary", "secondary", "outline"],
                  "defaultValue": "outline"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
